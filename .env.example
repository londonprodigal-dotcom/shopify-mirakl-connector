# ─── Shopify ────────────────────────────────────────────────────────────────
# Your myshopify domain, e.g. louchelondon.myshopify.com
SHOPIFY_STORE_DOMAIN=louchelondon.myshopify.com

# Admin API access token with scopes:
#   read_products, read_inventory, read_product_listings
SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# API version – defaults to 2024-01
# SHOPIFY_API_VERSION=2024-01

# ─── Mirakl ─────────────────────────────────────────────────────────────────
# Base URL of the Mirakl operator instance (no trailing slash)
MIRAKL_BASE_URL=https://debenhamsuk-prod.mirakl.net

# Seller API key (from My Account → API Key in Mirakl back office)
MIRAKL_API_KEY=your-mirakl-api-key-here

# Your shop ID in Mirakl (visible in back office URL or shop settings)
# Leave blank if your API key only has access to one shop.
MIRAKL_SHOP_ID=

# ─── Paths (optional overrides) ──────────────────────────────────────────────
# Override where the connector looks for Mirakl template files.
# Useful on Railway/servers where templates live on a mounted volume.
# Equivalent to the --templates-path CLI flag.
# TEMPLATES_PATH=/mnt/templates

# ─── Database ─────────────────────────────────────────────────
# Postgres connection string (Railway provides this automatically)
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ─── Stock Buffer ─────────────────────────────────────────────
# Subtract N units from all Mirakl stock pushes (default: 0)
STOCK_BUFFER=0
# If Shopify qty <= N, set Mirakl qty to 0 (default: 2)
STOCK_HOLDBACK_LAST_N=2

# ─── Worker ───────────────────────────────────────────────────
# Unique worker instance ID (default: hostname)
# WORKER_ID=worker-1
# Job poll interval in ms (default: 1000)
# JOB_POLL_INTERVAL_MS=1000
# Mark running jobs as stale after this many ms (default: 1800000 = 30min)
# JOB_STALE_TIMEOUT_MS=1800000

# ─── Reconciliation ──────────────────────────────────────────
# Stock reconciliation interval in ms (default: 900000 = 15min)
# RECONCILE_STOCK_INTERVAL_MS=900000
# Order reconciliation interval in ms (default: 900000 = 15min)
# RECONCILE_ORDER_INTERVAL_MS=900000
# Batch sync interval in ms (default: 21600000 = 6hr)
# BATCH_SYNC_INTERVAL_MS=21600000
# Nightly full audit hour in UTC (default: 2 = 02:00 UTC)
# FULL_AUDIT_HOUR_UTC=2

# ─── Alerts ───────────────────────────────────────────────────
# Slack or Discord incoming webhook URL for alerts
# ALERT_WEBHOOK_URL=https://discord.com/api/webhooks/...
# Alert thresholds
# DRIFT_ALERT_THRESHOLD=5
# DRIFT_CRITICAL_COUNT=10
# QUEUE_BACKLOG_WARN=20
# QUEUE_BACKLOG_CRIT=50
# RECONCILE_STALE_MINUTES=45

# ─── Degradation Mode ────────────────────────────────────────
# Accept and persist events but don't process jobs (default: false)
# DEGRADED_MODE=false
