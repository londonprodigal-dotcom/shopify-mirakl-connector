{
  "name": "shopify-mirakl-connector",
  "version": "1.0.0",
  "description": "Syncs Shopify products into Debenhams Marketplace via Mirakl seller APIs",
  "main": "dist/index.js",
  "bin": {
    "mirakl-sync": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "sync:dry": "ts-node src/index.ts sync --dry-run",
    "sync:upload": "ts-node src/index.ts sync",
    "sync:incremental": "ts-node src/index.ts sync --incremental",
    "sync:stock": "ts-node src/index.ts sync --stock-only"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "commander": "^12.1.0",
    "csv-parse": "^5.5.6",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "form-data": "^4.0.0",
    "js-yaml": "^4.1.0",
    "sharp": "^0.33.5",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.19.35",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
